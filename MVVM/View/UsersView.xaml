<UserControl x:Class="Gotyeam.MVVM.View.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             xmlns:local="clr-namespace:Gotyeam.MVVM.View"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <local:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <local:Base64ImageConverter x:Key="Base64ImageConverter" />
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <!-- Panel Lateral de Detalles -->
            <ColumnDefinition Width="400"/>
        </Grid.ColumnDefinitions>

        <!-- Titulo y Status -->
        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
            <TextBlock Text="Gestión de Clientes" Foreground="White" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="{Binding StatusMessage}" Foreground="LightGray" FontSize="14" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Barra de Controles -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="Transparent" Height="40" CornerRadius="20" Padding="15,0" Margin="0,0,20,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Estado:" Foreground="#A0A0B0" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox ItemsSource="{Binding FiltrosEstado}" SelectedItem="{Binding SelectedFiltroEstado}" Width="100" VerticalAlignment="Center"
                              Background="White" BorderThickness="0" Foreground="Black" Padding="5,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#252535" CornerRadius="20" Height="40" Margin="0,0,15,0" Padding="15,0,5,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <fa:ImageAwesome Icon="Search" Grid.Column="0" Height="14" Foreground="#A0A0B0" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}" 
                             VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Foreground="White"
                             CaretBrush="White"/>
                    <Button Grid.Column="2" Content="Buscar" Command="{Binding BuscarUsuariosCommand}"
                            Background="Transparent" Foreground="{StaticResource color3}" FontWeight="Bold" BorderThickness="0" Padding="10,0"/>
                </Grid>
            </Border>

            <Button Grid.Column="3" Content="+ Nuevo Usuario" Command="{Binding NuevoUsuarioCommand}"
                    Background="{StaticResource color3}" Foreground="White" FontWeight="Bold" Height="40" Padding="20,0"
                    Visibility="{Binding CanManageUsers, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="20" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- User Cards using a custom style ListBox for easy selection binding -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="-10,0,-10,0">
            <ListBox ItemsSource="{Binding Usuarios}" SelectedItem="{Binding SelectedUsuario}"
                     Background="Transparent" BorderThickness="0" 
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Background="#1E1E2D" CornerRadius="12" Margin="10" Width="260" Padding="20" Cursor="Hand">
                                        <ContentPresenter />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0" Margin="0,0,15,0">
                                <Image Source="{Binding foto_url, Converter={StaticResource Base64ImageConverter}, TargetNullValue='https://via.placeholder.com/60', FallbackValue='https://via.placeholder.com/60'}" Width="60" Height="60" Stretch="UniformToFill">
                                    <Image.Clip>
                                        <EllipseGeometry RadiusX="30" RadiusY="30" Center="30,30"/>
                                    </Image.Clip>
                                </Image>
                                <Ellipse Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,2,2" Stroke="#1E1E2D" StrokeThickness="2">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#E53935"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding activo}" Value="True">
                                                    <Setter Property="Fill" Value="#43A047"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                            </Grid>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding username}" FontWeight="Bold" FontSize="16" Foreground="{StaticResource color3}" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding NombreCompleto}" Foreground="White" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding correo}" Foreground="#A0A0B0" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,2,0,5"/>
                                
                                <Border CornerRadius="6" Padding="8,3" HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#33E53935"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding activo}" Value="True">
                                                    <Setter Property="Background" Value="#3343A047"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="10" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Bloqueado"/>
                                                <Setter Property="Foreground" Value="#E53935"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding activo}" Value="True">
                                                        <Setter Property="Text" Value="Activo"/>
                                                        <Setter Property="Foreground" Value="#43A047"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>

        <!-- Panel de Detalles Modal Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4" Background="#CC000000" Margin="-20"
                Visibility="{Binding IsDetailVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                
            <Border Background="#1A1A2A" CornerRadius="12" Width="450" Padding="25" VerticalAlignment="Center" HorizontalAlignment="Center"
                    BorderBrush="#252535" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.5" Direction="270" ShadowDepth="10"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Left" Margin="0,0,0,15">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Detalles del Cliente"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCreatingUsuario}" Value="True">
                                        <Setter Property="Text" Value="Registrar Nuevo Cliente"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Button Grid.Row="0" Background="Transparent" BorderThickness="0" HorizontalAlignment="Right" VerticalAlignment="Top" 
                            Command="{Binding CloseDetailCommand}" Foreground="#A0A0B0" Margin="0,-10,-10,0" ToolTip="Cerrar" Cursor="Hand">
                        <fa:ImageAwesome Icon="Times" Height="16" Foreground="#A0A0B0" Margin="5"/>
                    </Button>

                    <StackPanel Grid.Row="1" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                            <Button Background="Transparent" BorderThickness="0" ToolTip="Imagen de perfil" Margin="0,0,15,0">
                                <Grid>
                                    <Image Source="{Binding SelectedUsuario.foto_url, Converter={StaticResource Base64ImageConverter}, TargetNullValue='https://via.placeholder.com/100', FallbackValue='https://via.placeholder.com/100'}" Width="80" Height="80" Stretch="UniformToFill">
                                        <Image.Clip>
                                            <EllipseGeometry RadiusX="40" RadiusY="40" Center="40,40"/>
                                        </Image.Clip>
                                    </Image>
                                </Grid>
                            </Button>

                        </StackPanel>
                        
                        <Grid Margin="10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Username" Foreground="Gray" FontSize="11"/>
                            <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding SelectedUsuario.username}" IsReadOnly="{Binding CanManageUsers, Converter={StaticResource InverseBooleanConverter}}" Background="#2C2C3E" Foreground="White" Padding="6" BorderThickness="0" Margin="0,2,0,8"/>
                            
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Contraseña" Foreground="Gray" FontSize="11"/>
                            <PasswordBox Name="txtPassword" Grid.Row="1" Grid.Column="2" IsEnabled="{Binding CanManageUsers}" Background="#2C2C3E" Foreground="White" Padding="6" BorderThickness="0" Margin="0,2,0,8"/>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Correo" Foreground="Gray" FontSize="11"/>
                            <TextBox Grid.Row="3" Grid.Column="0" Text="{Binding SelectedUsuario.correo}" IsReadOnly="{Binding CanManageUsers, Converter={StaticResource InverseBooleanConverter}}" Background="#2C2C3E" Foreground="White" Padding="6" BorderThickness="0" Margin="0,2,0,8"/>
                            
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Nombre" Foreground="Gray" FontSize="11"/>
                            <TextBox Grid.Row="5" Grid.Column="0" Text="{Binding SelectedUsuario.nombre}" IsReadOnly="{Binding CanManageUsers, Converter={StaticResource InverseBooleanConverter}}" Background="#2C2C3E" Foreground="White" Padding="6" BorderThickness="0" Margin="0,2,0,8"/>
                            
                            <TextBlock Grid.Row="4" Grid.Column="2" Text="Apellidos" Foreground="Gray" FontSize="11"/>
                            <StackPanel Grid.Row="5" Grid.Column="2" Orientation="Horizontal">
                                <TextBox Text="{Binding SelectedUsuario.apellido1}" IsReadOnly="{Binding CanManageUsers, Converter={StaticResource InverseBooleanConverter}}" Background="#2C2C3E" Foreground="White" Padding="6" BorderThickness="0" Margin="0,2,5,8" Width="70"/>
                                <TextBox Text="{Binding SelectedUsuario.apellido2}" IsReadOnly="{Binding CanManageUsers, Converter={StaticResource InverseBooleanConverter}}" Background="#2C2C3E" Foreground="White" Padding="6" BorderThickness="0" Margin="0,2,0,8" Width="70"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="{Binding SelectedUsuario.fecha_registro, StringFormat='Registrado: {0}'}" Foreground="Gray" FontSize="11" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- Action Buttons -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,15">
                        <Button Command="{Binding UpdateUserCommand}" CommandParameter="{Binding ElementName=txtPassword}"
                                Foreground="White" Padding="15,8" MinWidth="120" Cursor="Hand" BorderThickness="0" Margin="0,0,10,0"
                                Visibility="{Binding CanManageUsers, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="{StaticResource color2}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Content" Value="Guardar Cambios"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCreatingUsuario}" Value="True">
                                            <Setter Property="Content" Value="Registrar"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Command="{Binding ToggleUserStatusCommand}"
                                Foreground="White" Padding="15,8" MinWidth="150" Cursor="Hand" BorderThickness="0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="{Binding CanManageUsers, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <Setter Property="Background" Value="#dc3545"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Content" Value="Bloquear Cliente"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedUsuario.activo}" Value="False">
                                            <Setter Property="Background" Value="#28a745"/>
                                            <Setter Property="Content" Value="Desbloquear Cliente"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsCreatingUsuario}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <TextBlock Grid.Row="3" Text="Reseñas del Cliente" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCreatingUsuario}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    
                    <!-- Lista de Reseñas -->
                    <ListBox Grid.Row="4" ItemsSource="{Binding ResennasUsuario}" MaxHeight="250"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.Style>
                            <Style TargetType="ListBox">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCreatingUsuario}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Style>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#202030" CornerRadius="8" Padding="10" Margin="0,0,0,10" BorderBrush="#353545" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Juego -->
                                        <Image Grid.Column="0" Source="{Binding portada_url}" Width="60" Height="60" Stretch="UniformToFill" VerticalAlignment="Top" Margin="0,0,10,0"/>
                                        
                                        <!-- Contenido de Reseña -->
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding titulo}" Foreground="White" FontWeight="Bold"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,5">
                                                <fa:ImageAwesome Icon="Star" Height="10" Foreground="Yellow" Margin="0,0,5,0"/>
                                                <TextBlock Text="{Binding puntuacion, StringFormat='{}{0}/5'}" Foreground="LightGray" FontSize="12" Margin="0,0,10,0"/>
                                                
                                                <Border Background="{StaticResource color1}" CornerRadius="3" Padding="4,1" Visibility="{Binding recomendado, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="Recomendado" FontSize="10" Foreground="White"/>
                                                </Border>
                                                <Border Background="#E53935" CornerRadius="3" Padding="4,1" Visibility="{Binding recomendado, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                    <TextBlock Text="No Recomendado" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding comentario}" Foreground="Gray" TextWrapping="Wrap" MaxHeight="60" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Botón Eliminar Reseña -->
                                        <Button Grid.Column="2" Background="Transparent" BorderThickness="0" VerticalAlignment="Top" Cursor="Hand"
                                                Command="{Binding DataContext.DeleteReviewCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding _id}" ToolTip="Eliminar Reseña"
                                                Visibility="{Binding DataContext.CanManageUsers, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <fa:ImageAwesome Icon="Trash" Height="15" Foreground="IndianRed"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
