<UserControl x:Class="Gotyeam.MVVM.View.EmployeesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             xmlns:local="clr-namespace:Gotyeam.MVVM.View"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <local:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <local:Base64ImageConverter x:Key="Base64ImageConverter" />
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Titulo y Status -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Gestión de Empleados" Foreground="White" FontSize="26" FontWeight="Bold"/>
            <TextBlock Text="{Binding StatusMessage}" Foreground="#A0A0B0" FontSize="14" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Barra de Controles -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="Transparent" CornerRadius="20" Height="40" Padding="15,0" Margin="0,0,20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Estado:" Foreground="#A0A0B0" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox ItemsSource="{Binding FiltrosEstado}" SelectedItem="{Binding SelectedFiltroEstado}" Width="100" VerticalAlignment="Center"
                              Background="White" BorderThickness="0" Foreground="Black" Padding="5,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#252535" CornerRadius="20" Height="40" Margin="0,0,15,0" Padding="15,0,5,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <fa:ImageAwesome Icon="Search" Grid.Column="0" Height="14" Foreground="#A0A0B0" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}" 
                             VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Foreground="White"
                             CaretBrush="White"/>
                    <Button Grid.Column="2" Content="Buscar" Command="{Binding BuscarEmpleadosCommand}"
                            Background="Transparent" Foreground="{StaticResource color3}" FontWeight="Bold" BorderThickness="0" Padding="10,0"/>
                </Grid>
            </Border>

            <Button Grid.Column="3" Content="+ Nuevo Empleado" Command="{Binding NuevoEmpleadoCommand}"
                    Background="{StaticResource color3}" Foreground="White" FontWeight="Bold" Height="40" Padding="20,0"
                    Visibility="{Binding CanManageEmployees, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="20" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- Employee Cards -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="-10,0,-10,0">
            <ItemsControl ItemsSource="{Binding Empleados}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#1E1E2D" CornerRadius="12" Margin="10" Width="260" Padding="20">
                            <!-- Make the whole card clickable to edit -->
                            <Border.InputBindings>
                                <MouseBinding Gesture="LeftClick" 
                                              Command="{Binding DataContext.EditarEmpleadoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                              CommandParameter="{Binding}" />
                            </Border.InputBindings>
                            <Border.Cursor>
                                <Cursor>Hand</Cursor>
                            </Border.Cursor>
                            <!-- Card Hover FX optional -> for now simple static -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Profile picture with status dot -->
                                <Grid Grid.Column="0" Margin="0,0,15,0">
                                    <Image Source="{Binding foto_url, Converter={StaticResource Base64ImageConverter}, TargetNullValue='https://via.placeholder.com/60', FallbackValue='https://via.placeholder.com/60'}" Width="60" Height="60" Stretch="UniformToFill">
                                        <Image.Clip>
                                            <EllipseGeometry RadiusX="30" RadiusY="30" Center="30,30"/>
                                        </Image.Clip>
                                    </Image>
                                    <Ellipse Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,2,2" Stroke="#1E1E2D" StrokeThickness="2">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#E53935"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding activo}" Value="True">
                                                        <Setter Property="Fill" Value="#43A047"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                </Grid>

                                <!-- Info -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding NombreCompleto}" Foreground="White" FontWeight="Bold" FontSize="16" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding correo}" Foreground="#A0A0B0" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,4,0,10"/>
                                    
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Nivel Rol Pill -->
                                        <Border Background="#252535" CornerRadius="6" Padding="8,4" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding nivel_rol, StringFormat='Nivel {0}'}" Foreground="#8C8CFF" FontSize="11" FontWeight="SemiBold"/>
                                        </Border>
                                        <!-- Status Pill -->
                                        <Border CornerRadius="6" Padding="8,4">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#33E53935"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding activo}" Value="True">
                                                            <Setter Property="Background" Value="#3343A047"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="11" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Inactivo"/>
                                                        <Setter Property="Foreground" Value="#E53935"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding activo}" Value="True">
                                                                <Setter Property="Text" Value="Activo"/>
                                                                <Setter Property="Foreground" Value="#43A047"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Actions -->
                                <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Top" HorizontalAlignment="Right">
                                    <Button Background="Transparent" BorderThickness="0" Margin="0,0,0,15" ToolTip="Editar" Cursor="Hand"
                                            Command="{Binding DataContext.EditarEmpleadoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Visibility="{Binding IsEditable, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <fa:ImageAwesome Icon="Pencil" Height="14" Foreground="{StaticResource color4}"/>
                                    </Button>
                                    <Button Background="Transparent" BorderThickness="0" ToolTip="Bloquear/Activar" Cursor="Hand"
                                            Command="{Binding DataContext.ToggleEstadoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Visibility="{Binding IsEditable, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <fa:ImageAwesome Icon="Ban" Height="14" Foreground="IndianRed"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Modal Overlay for Creating/Editing -->
        <Border Grid.Row="0" Grid.RowSpan="3" Background="#CC000000" Margin="-20"
                Visibility="{Binding IsFormVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                
            <Border Background="#1A1A2A" CornerRadius="12" Width="400" Padding="25" VerticalAlignment="Center" HorizontalAlignment="Center"
                    BorderBrush="#252535" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.5" Direction="270" ShadowDepth="10"/>
                </Border.Effect>
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Registrar Empleado"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                        <Setter Property="Text" Value="Editar Empleado"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,20" MaxHeight="450">
                        <StackPanel DataContext="{Binding EmpleadoForm}">
                            
                            <TextBlock Text="Nombre:" Foreground="LightGray" FontSize="12" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding nombre}" Margin="0,0,0,15" Background="#2C2C3E" Foreground="White" Padding="8" BorderThickness="0"/>

                            <TextBlock Text="Primer Apellido:" Foreground="LightGray" FontSize="12" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding apellido1}" Margin="0,0,0,15" Background="#2C2C3E" Foreground="White" Padding="8" BorderThickness="0"/>

                            <TextBlock Text="Segundo Apellido:" Foreground="LightGray" FontSize="12" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding apellido2}" Margin="0,0,0,15" Background="#2C2C3E" Foreground="White" Padding="8" BorderThickness="0"/>

                            <TextBlock Text="Correo Electrónico:" Foreground="LightGray" FontSize="12" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding correo}" Margin="0,0,0,15" Background="#2C2C3E" Foreground="White" Padding="8" BorderThickness="0"/>

                            <TextBlock Text="Contraseña:" Foreground="LightGray" FontSize="12" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding contrasenna}" Margin="0,0,0,15" Background="#2C2C3E" Foreground="White" Padding="8" BorderThickness="0"/>

                            <TextBlock Text="Nivel de Rol:" Foreground="LightGray" FontSize="12" Margin="0,0,0,5"/>
                            <ComboBox ItemsSource="{Binding DataContext.RolesDisponibles, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      SelectedItem="{Binding nivel_rol}" Margin="0,0,0,15" Height="32"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,20">
                                <Button Background="Transparent" BorderThickness="0" Command="{Binding DataContext.SeleccionarImagenCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" ToolTip="Cambiar imagen de perfil" Cursor="Hand" Margin="0,0,15,0">
                                    <Grid>
                                        <Image Source="{Binding imagen_url, Converter={StaticResource Base64ImageConverter}, TargetNullValue='https://via.placeholder.com/100', FallbackValue='https://via.placeholder.com/100'}" Width="80" Height="80" Stretch="UniformToFill">
                                            <Image.Clip>
                                                <EllipseGeometry RadiusX="40" RadiusY="40" Center="40,40"/>
                                            </Image.Clip>
                                        </Image>
                                        <Border Background="#80000000" CornerRadius="40">
                                            <fa:ImageAwesome Icon="Camera" Height="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </Button>

                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Botones de Acción Formulario -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancelar" Command="{Binding CancelarFormCommand}"
                                Background="Transparent" Foreground="#A0A0B0" Padding="15,8" Margin="0,0,10,0" BorderThickness="0" Cursor="Hand"/>

                        <Button Content="Guardar" Command="{Binding GuardarEmpleadoCommand}"
                                Background="{StaticResource color3}" Foreground="White" Padding="20,8" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

    </Grid>
</UserControl>
