<UserControl x:Class="Gotyeam.MVVM.View.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             xmlns:local="clr-namespace:Gotyeam.MVVM.View"
             Background="Transparent">
    
    <UserControl.Resources>
        <local:Base64ImageConverter x:Key="Base64ImageConverter" />
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Titulo y Status -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Configuración de Perfil" Foreground="White" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="{Binding StatusMessage}" Foreground="LightGray" FontSize="14" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Formulario -->
        <Border Grid.Row="1" Background="#1A1A2A" CornerRadius="10" Padding="30" HorizontalAlignment="Left" Width="500">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Foto de Perfil Actual -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Button Background="Transparent" BorderThickness="0" Command="{Binding SeleccionarImagenCommand}" ToolTip="Cambiar imagen de perfil" Cursor="Hand">
                        <Grid>
                            <Image Source="{Binding MiPerfil.imagen_url, Converter={StaticResource Base64ImageConverter}, TargetNullValue='https://via.placeholder.com/120', FallbackValue='https://via.placeholder.com/120'}" Width="120" Height="120" Stretch="UniformToFill" HorizontalAlignment="Center">
                                <Image.Clip>
                                    <EllipseGeometry RadiusX="60" RadiusY="60" Center="60,60"/>
                                </Image.Clip>
                            </Image>
                            <Border Background="#80000000" CornerRadius="60">
                                <fa:ImageAwesome Icon="Camera" Height="30" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Button>
                    <TextBlock Text="{Binding MiPerfil.correo}" Foreground="LightGray" FontSize="14" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,10,0,20">
                    <StackPanel DataContext="{Binding MiPerfil}">
                        
                        <TextBlock Text="Nombre:" Foreground="LightGray" FontSize="12"/>
                        <TextBox Text="{Binding nombre}" Margin="0,0,0,15" Background="#2C2C3E" Foreground="White" Padding="8" FontSize="14" BorderThickness="0"/>

                        <TextBlock Text="Primer Apellido:" Foreground="LightGray" FontSize="12"/>
                        <TextBox Text="{Binding apellido1}" Margin="0,0,0,15" Background="#2C2C3E" Foreground="White" Padding="8" FontSize="14" BorderThickness="0"/>

                        <TextBlock Text="Segundo Apellido:" Foreground="LightGray" FontSize="12"/>
                        <TextBox Text="{Binding apellido2}" Margin="0,0,0,15" Background="#2C2C3E" Foreground="White" Padding="8" FontSize="14" BorderThickness="0"/>

                        <TextBlock Text="Correo Electrónico:" Foreground="LightGray" FontSize="12"/>
                        <TextBox Text="{Binding correo}" Margin="0,0,0,15" Background="#2C2C3E" Foreground="White" Padding="8" FontSize="14" BorderThickness="0"/>

                        <TextBlock Text="Contraseña (dejar en blanco si no se cambia):" Foreground="LightGray" FontSize="12"/>
                        <!-- Note: Binding to contrasenna requires checking if it's handled safely. Ideally use PasswordBox, but since our model is simple text for now we use TextBox to maintain MVVM binding without code-behind helpers. -->
                        <TextBox Text="{Binding contrasenna}" Margin="0,0,0,15" Background="#2C2C3E" Foreground="White" Padding="8" FontSize="14" BorderThickness="0"/>

                        <TextBlock Text="Nivel de Rol:" Foreground="LightGray" FontSize="12"/>
                        <!-- ReadOnly as an employee cannot change their own role -->
                        <TextBox Text="{Binding nivel_rol}" IsReadOnly="True" Margin="0,0,0,15" Background="#2C2C3E" Foreground="DarkGray" Padding="8" FontSize="14" BorderThickness="0"/>



                    </StackPanel>
                </ScrollViewer>

                <!-- Botones de Acción -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Guardar Cambios" Command="{Binding GuardarCambiosCommand}"
                            Background="#28a745" Foreground="White" Padding="20,10" FontSize="14" FontWeight="Bold" BorderThickness="0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
