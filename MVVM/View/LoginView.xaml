<Window x:Class="Gotyeam.MVVM.View.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Gotyeam.MVVM.View"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        mc:Ignorable="d"
        Title="LoginView" Height="550" Width="800"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        MouseDown="Window_MouseDown"> <!--para poder arrastar la ventana con el raton-->

    <Border CornerRadius="12">
        
        <!--Imagen de fondo-->
        <!--teniendo como ejemplo un cuadro, border no solo se refiere al marco del cuadro, sino tmb al carton que hay de fondo, por lo que
        con esto le estamos indicando que pinte el carton que hay de fondo con un broche que pinta una imagen-->
        <Border.Background>
            <ImageBrush ImageSource="/Imagenes/gotyeam_fondo.png"
                        Stretch="None"/>
        </Border.Background>

        <!--Contenido principal-->
        <Border CornerRadius="10"                    
            BorderThickness="2"
            Opacity="0.9"> <!--para que se pueda ver la imagen de fondo-->

            <!--Borde degradado-->
            <!--le digo que pinte el borde del cuadro con un degradado empezando de superior izquierda a inferior derecha, tmb le indico que haga 
            3 paradas, al principio del recorrido pinte de un color, al llegar al 75% del camino pinte de otro color y al final del recorrido lo pinte
            de otro, el trayecto entre parada y parada se va mezclando colores hasta llegar al color exacto de la parada -->
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{StaticResource winBorderColor1}" Offset="0"/>
                    <GradientStop Color="{StaticResource winBorderColor2}" Offset="0.75"/>
                    <GradientStop Color="{StaticResource winBorderColor3}" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            
            <!--Fondo degradado-->
            <Border.Background>
                <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                    <GradientStop Color="{StaticResource primaryBackColor1}" Offset="0"/>
                    <GradientStop Color="{StaticResource primaryBackColor2}" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <!--Contenido principal-->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/> <!--para el titulo de la ventana y los botones minimizar y cerrar-->
                    <RowDefinition/> <!--para el formulario del login-->
                </Grid.RowDefinitions>

                <!--Titulo ventana y botones minimizar y cerrar-->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/> <!--titulo ventana-->
                        <ColumnDefinition Width="25"/> <!--boton minimizar-->
                        <ColumnDefinition Width="25"/> <!--boton cerrar-->
                        <ColumnDefinition Width="5"/> <!--se utiliza como margen-->
                    </Grid.ColumnDefinitions>
                    
                    <!--Titulo ventana-->
                    <TextBlock Text="INICIO SESIÓN"
                               Foreground="{StaticResource plainTextColor1}"
                               FontSize="10"
                               FontFamily="Montserrat"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"/>

                    <!--Boton minimizar-->
                    <Button x:Name="btnMinimizar"
                            Style="{StaticResource controlButton}"
                            Tag="{StaticResource color8}"
                            Grid.Column="1"
                            Click="btnMinimizar_Click"
                            Cursor="Hand">
                        <fa:ImageAwesome Icon="WindowMinimize" Style="{StaticResource controlButtonIcon}"/>
                    </Button>

                    <!--Boton cerrar-->
                    <Button x:Name="btnCerrar"   
                            Cursor="Hand"
                            Grid.Column="2"
                            Click="btnCerrar_Click"
                            Style="{StaticResource controlButton}"
                            Tag="{StaticResource color4}">
                        <fa:ImageAwesome Icon="Times" Style="{StaticResource controlButtonIcon}"/>
                    </Button>
                </Grid>

                <!--Logo y formulario de inicio de sesión-->
                <StackPanel Width="220"
                            Grid.Row="1"
                            Orientation="Vertical"
                            Margin="0,35,0,0">
                    
                    <!--Logo de la aplicacion-->
                    <Image Source="/Imagenes/gotyeam_logo.png"
                           Width="150" Height="100"/>
                    
                    <!--Nombre aplicacion-->
                    <TextBlock Text="GOTYEAM"
                               Foreground="White"
                               FontSize="25"
                               FontWeight="Medium"
                               FontFamily="Montserrat"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"/>

                    <!--Slogan aplicacion-->
                    <TextBlock Text="Elevando la administración al estándar de un auténtico GOTY"
                               Foreground="LightGray"
                               FontSize="12"
                               FontWeight="Medium"
                               FontFamily="Montserrat"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,5,0,0"/>
                    
                    <!--Texto correo-->
                    <TextBlock Text="Correo electrónico"
                               Foreground="DarkGray"
                               FontSize="12"
                               FontWeight="Medium"
                               FontFamily="Montserrat"                             
                               Margin="0,35,0,0"/>

                    <!--Caja de texto correo-->
                    <TextBox x:Name="txtCorreo"
                             Text ="{Binding Correo, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13"
                             FontWeight="Medium"
                             FontFamily="Montserrat"                            
                             Foreground="White"
                             CaretBrush="LightGray"
                             BorderBrush="DarkGray"
                             BorderThickness="0,0,0,2"
                             Height="28"
                             VerticalContentAlignment="Center"
                             Margin="0,5,0,0"
                             Padding="20,0,0,0">
                        
                        <!--imagen de correo como fondo del textbox-->
                        <TextBox.Background>
                            <ImageBrush ImageSource="/Imagenes/correo.png"
                                        Stretch="None"
                                        AlignmentX="Left"/>
                        </TextBox.Background>
                    </TextBox>

                    <!--Texto contraseña-->
                    <TextBlock Text="Contraseña"
                               Foreground="DarkGray"
                               FontSize="12"
                               FontWeight="Medium"
                               FontFamily="Montserrat"                             
                               Margin="0,15,0,0"/>

                    <!--Caja de texto contraseña-->
                    <PasswordBox x:Name="txtPass"
                             FontSize="13"
                             FontWeight="Medium"
                             FontFamily="Montserrat"                            
                             Foreground="White"
                             CaretBrush="LightGray"
                             BorderBrush="DarkGray"
                             BorderThickness="0,0,0,2"
                             Height="28"
                             VerticalContentAlignment="Center"
                             Margin="0,5,0,0"
                             Padding="20,0,0,0">
                        
                        <!--imagen de llave como fondo del passwordbox-->
                        <PasswordBox.Background>
                            <ImageBrush ImageSource="/Imagenes/llave.png"
                                        Stretch="None"
                                        AlignmentX="Left"/>
                        </PasswordBox.Background>
                    </PasswordBox>

                    <!--Boton iniciar sesion-->
                    <Button x:Name="btnLogin"     
                            Command="{Binding LoginCommand}"
                            Style="{StaticResource LoginBtnLoginStyle}"
                            BorderThickness="0"
                            Content="Iniciar sesión"
                            Foreground="White"
                            FontSize="12"
                            FontFamily="Montserrat"
                            Cursor="Hand"                           
                            Margin="0,30,0,0" Click="btnLogin_Click">
                    </Button>

                </StackPanel>
                
            </Grid>
            
        </Border>

    </Border>
</Window>

    