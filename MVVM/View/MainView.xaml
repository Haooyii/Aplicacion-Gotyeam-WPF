<Window x:Class="Gotyeam.MVVM.View.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Gotyeam.MVVM.View"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        mc:Ignorable="d"
        Title="MainView"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True">

    <!--Contenido principal-->
    <Border CornerRadius="10"                    
    BorderThickness="2">

        <!--Borde degradado-->
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{StaticResource winBorderColor1}" Offset="0"/>
                <GradientStop Color="{StaticResource winBorderColor2}" Offset="0.75"/>
                <GradientStop Color="{StaticResource winBorderColor3}" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>

        <Grid>

            <Grid.ColumnDefinitions>
                <!--Menu de navegación-->
                <ColumnDefinition Width="250"/>
                <!--Contenido principal-->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!--Menú de navegación-->
            <Border CornerRadius="10,0,0,10"
                    Grid.Column="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0.7">
                        <GradientStop Color="{StaticResource secondaryBackColor1}" Offset="0"/>
                        <GradientStop Color="{StaticResource secondaryBackColor2}" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!--Logo-->
                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Height="55"
                                Margin="15,45,0,50">
                        <Image Source="/Imagenes/gotyeam_logo.png"/>
                        <TextBlock Text="GOTYEAM"
                                   Foreground="{StaticResource titleColor2}"
                                   FontSize="25"
                                   FontFamily="Montserrat"
                                   FontWeight="Medium"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"/>

                    </StackPanel>

                    <!--Menú botones-->
                    <StackPanel Grid.Row="1" VerticalAlignment="Top">
                        <!--Boton juegos-->
                        <RadioButton Style="{StaticResource menuButton}"
                                     Tag="{StaticResource color1}"
                                     IsChecked="True"
                                     Command="{Binding GamesViewCommand}">

                            <StackPanel Orientation="Horizontal">
                                <fa:ImageAwesome Icon="Gamepad" Style="{StaticResource menuButtonIcon}"/>
                                <TextBlock Text="Videojuegos" Style="{StaticResource menuButtonText}"/>
                            </StackPanel>
                        </RadioButton>

                        <!--Boton usuarios-->
                        <RadioButton Style="{StaticResource menuButton}"
                                     Tag="{StaticResource color2}"
                                     Command="{Binding UsersViewCommand}">

                            <StackPanel Orientation="Horizontal">
                                <fa:ImageAwesome Icon="User" Style="{StaticResource menuButtonIcon}"/>
                                <TextBlock Text="Usuarios" Style="{StaticResource menuButtonText}"/>
                            </StackPanel>
                        </RadioButton>

                        <!--Boton empleados-->
                        <RadioButton Style="{StaticResource menuButton}"
                                     Tag="{StaticResource color3}"
                                     Command="{Binding EmployeesViewCommand}">

                            <StackPanel Orientation="Horizontal">
                                <fa:ImageAwesome Icon="Users" Style="{StaticResource menuButtonIcon}"/>
                                <TextBlock Text="Empleados" Style="{StaticResource menuButtonText}"/>
                            </StackPanel>
                        </RadioButton>

                        <!--Boton perfil-->
                        <RadioButton Style="{StaticResource menuButton}"
                                     Tag="{StaticResource color4}"
                                     Command="{Binding ProfileViewCommand}">

                            <StackPanel Orientation="Horizontal">
                                <fa:ImageAwesome Icon="IdCard" Style="{StaticResource menuButtonIcon}"/>
                                <TextBlock Text="Mi Perfil" Style="{StaticResource menuButtonText}"/>
                            </StackPanel>
                        </RadioButton>

                        <!--Boton ajustes-->
                        <RadioButton Style="{StaticResource menuButton}"
                                     Tag="{StaticResource color5}"
                                     Command="{Binding SettingsViewCommand}">

                            <StackPanel Orientation="Horizontal">
                                <fa:ImageAwesome Icon="Gear" Style="{StaticResource menuButtonIcon}"/>
                                <TextBlock Text="Configuración" Style="{StaticResource menuButtonText}"/>
                            </StackPanel>
                        </RadioButton>

                        <!--Boton acerca de-->
                        <RadioButton Style="{StaticResource menuButton}"
                                     Tag="{StaticResource color6}"
                                     Command="{Binding AboutViewCommand}">

                            <StackPanel Orientation="Horizontal">
                                <fa:ImageAwesome Icon="InfoCircle" Style="{StaticResource menuButtonIcon}"/>
                                <TextBlock Text="Acerca de" Style="{StaticResource menuButtonText}"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                                      

                    <!--Boton cerrar sesión-->
                    <Button Grid.Row="2"
                            Style="{StaticResource exitMenuButton}"
                            Tag="{StaticResource color7}"
                            Click="btnCerrarSesion_Click">

                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="SignOut" Style="{StaticResource menuButtonIcon}"/>
                            <TextBlock Text="Cerrar sesión" Style="{StaticResource menuButtonText}"/>
                        </StackPanel>
                    </Button>

                </Grid>
            </Border>

            <!--Contenido principal-->
            <Border CornerRadius="0,10,10,0"
                    Grid.Column="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="1,1" EndPoint="0,0">
                        <GradientStop Color="{StaticResource primaryBackColor1}" Offset="0"/>
                        <GradientStop Color="{StaticResource primaryBackColor2}" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Grid.RowDefinitions>
                        <!--Barra de control-->
                        <RowDefinition Height="25"/>
                        <!--Encabezado de seccion-->
                        <RowDefinition Height="35"/>
                        <!--Contenido-->
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!--Barra de control-->
                    <StackPanel x:Name="pnlControlBar"
                                Grid.Row="0"
                                Orientation="Horizontal"
                                FlowDirection="RightToLeft"
                                Background="Transparent"
                                Margin="0,0,5,0"
                                MouseLeftButtonDown="pnlControlBar_MouseLeftButtonDown">

                        <!--Boton cerrar ventana-->
                        <Button x:Name="btnCerrar"
                                Style="{StaticResource controlButton}"
                                Tag="{StaticResource color4}"
                                Click="btnCerrar_Click">
                            <fa:ImageAwesome Icon="Times" Style="{StaticResource controlButtonIcon}"/>
                        </Button>

                        <!--Boton maximizar ventana-->
                        <Button x:Name="btnMaximizar"
                                Style="{StaticResource controlButton}"
                                Tag="{StaticResource color6}"
                                Click="btnMaximizar_Click">
                            <fa:ImageAwesome Icon="WindowMaximize" Style="{StaticResource controlButtonIcon}"/>
                        </Button>

                        <!--Boton minimizar ventana-->
                        <Button x:Name="btnMinimizar"
                                Style="{StaticResource controlButton}"
                                Tag="{StaticResource color8}"
                                Click="btnMinimizar_Click">
                            <fa:ImageAwesome Icon="WindowMinimize" Style="{StaticResource controlButtonIcon}"/>
                        </Button>

                    </StackPanel>
                    
                    <!--Encabezado de sección-->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        
                        <!--Caption-->
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <fa:ImageAwesome Icon="Gamepad"
                                             Height="20"
                                             Width="20"
                                             Foreground="{StaticResource titleColor2}"
                                             Margin="35,0,10,0"/>
                            <TextBlock Text="Videojuegos"
                                       Foreground="{StaticResource titleColor2}"
                                       FontSize="16"
                                       FontFamily="Montserrat"
                                       FontWeight="Medium"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <!--Opciones del usuario-->
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    FlowDirection="RightToLeft"
                                    VerticalAlignment="Center"
                                    Margin="0,0,10,0">
                            <TextBlock/>

                            <Ellipse Height="35" Width="35"
                                     Stroke="{StaticResource color2}"
                                     StrokeThickness="2"
                                     Margin="10,0,10,0">
                                <Ellipse.Fill>
                                    <ImageBrush x:Name="imgPerfilEmpleado" Stretch="UniformToFill"/>
                                </Ellipse.Fill>

                            </Ellipse>

                            <TextBlock x:Name="txtNombreCompletoEmpleado" 
                                       Text="...Cargando"
                                       Foreground="{StaticResource titleColor3}"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>

                        </StackPanel>
                        
                    </Grid>
                    
                    <ContentControl Grid.Row="2" Content="{Binding CurrentView}" Margin="10"/>
                    
                </Grid>
                
            </Border>

        </Grid>


    </Border>
</Window>
