<UserControl x:Class="Gotyeam.MVVM.View.GamesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             xmlns:local="clr-namespace:Gotyeam.MVVM.View"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <local:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <local:Base64ImageConverter x:Key="Base64ImageConverter" />
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <!-- Panel Lateral de Detalles -->
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Titulo y Status -->
        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
            <TextBlock Text="Gestión Catálogo de Juegos" Foreground="White" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="{Binding StatusMessage}" Foreground="LightGray" FontSize="14" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Barra de Búsqueda y Toggles -->
        <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Buscador RAWG" Command="{Binding SwitchToSearchCommand}" 
                    Background="{StaticResource color1}" Foreground="White" Padding="15,5" Margin="0,0,10,0"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0">
                <Button Content="Mis Juegos Añadidos" Command="{Binding SwitchToMisJuegosCommand}" 
                        Background="{StaticResource color2}" Foreground="White" Padding="15,5" Margin="0,0,10,0"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Visibility="{Binding IsShowingMisJuegos, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="Estado:" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox ItemsSource="{Binding FiltrosEstado}" SelectedItem="{Binding SelectedFiltroEstado}" Width="100" Margin="0,0,20,0" VerticalAlignment="Center" Background="White" Foreground="Black"/>
            </StackPanel>

            <TextBox Grid.Column="2" Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}" 
                     VerticalAlignment="Center" Height="30" Padding="5" Margin="0,0,10,0"
                     Visibility="{Binding IsShowingMisJuegos, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            </TextBox>

            <Button Grid.Column="3" Content="Buscar" Command="{Binding BuscarRawgCommand}"
                    Background="{StaticResource color4}" Foreground="White" Padding="15,5"
                    Visibility="{Binding IsShowingMisJuegos, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
        </Grid>

        <!-- Listados principales como Grid WrapPanels -->
        <ScrollViewer Grid.Row="2" Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="-10,0,-10,0">
            <StackPanel>
                <!-- ListBox de Busqueda RAWG usando Cards -->
                <ListBox ItemsSource="{Binding ResultadosBusqueda}" SelectedItem="{Binding SelectedRawgGame}"
                         Background="Transparent" BorderThickness="0"
                         Visibility="{Binding IsShowingMisJuegos, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="#1E1E2D" CornerRadius="12" Margin="10" Width="200" Padding="10" Cursor="Hand">
                                            <ContentPresenter />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <Border CornerRadius="8" ClipToBounds="True" Height="250" Margin="0,0,0,10">
                                    <Image Source="{Binding background_image, Converter={StaticResource Base64ImageConverter}}" Stretch="UniformToFill"/>
                                </Border>
                                <TextBlock Text="{Binding name}" FontWeight="Bold" FontSize="14" TextWrapping="Wrap" MaxHeight="40" TextTrimming="CharacterEllipsis" Foreground="{StaticResource color3}"/>
                                <TextBlock Text="{Binding released}" Foreground="#A0A0B0" FontSize="11" Margin="0,5,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- ListBox de Mis Juegos usando Cards -->
                <ListBox ItemsSource="{Binding MisJuegos}" SelectedItem="{Binding SelectedMiJuego}"
                         Background="Transparent" BorderThickness="0"
                         Visibility="{Binding IsShowingMisJuegos, Converter={StaticResource BooleanToVisibilityConverter}}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="#1E1E2D" CornerRadius="12" Margin="10" Width="200" Padding="10" Cursor="Hand">
                                            <ContentPresenter />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <Border CornerRadius="8" ClipToBounds="True" Height="250" Margin="0,0,0,10">
                                    <Grid>
                                        <Image Source="{Binding portada_url, Converter={StaticResource Base64ImageConverter}}" Stretch="UniformToFill"/>
                                        
                                        <!-- Status Indicator over Image -->
                                        <Border CornerRadius="4" Background="#E53935" HorizontalAlignment="Right" VerticalAlignment="Top" Padding="4,2" Margin="5"
                                                Visibility="{Binding activo, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                            <TextBlock Text="Inactivo" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </Border>
                                <TextBlock Text="{Binding titulo}" FontWeight="Bold" FontSize="14" TextWrapping="Wrap" MaxHeight="40" TextTrimming="CharacterEllipsis" Foreground="{StaticResource color3}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <TextBlock Text="{Binding fecha_lanzamiento}" Foreground="#A0A0B0" FontSize="11"/>
                                    <TextBlock Text=" • " Foreground="#A0A0B0" FontSize="11"/>
                                    <fa:ImageAwesome Icon="Star" Height="10" Foreground="Yellow" Margin="0,0,3,0"/>
                                    <TextBlock Text="{Binding valoracion_media, StringFormat=\{0:F1\}}" Foreground="Yellow" FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Text=" (" Foreground="#A0A0B0" FontSize="11"/>
                                    <TextBlock Text="{Binding cantidad_resennas}" Foreground="#A0A0B0" FontSize="11"/>
                                    <TextBlock Text=")" Foreground="#A0A0B0" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Panel de Detalle Derecho (Modal Overlay) -->
        <Border Grid.Row="0" Grid.RowSpan="4" Grid.ColumnSpan="2" Background="#CC000000" Margin="-20"
                Visibility="{Binding IsDetailVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                
            <Border Width="450" MaxHeight="700" Background="#1A1A2A" CornerRadius="12" Padding="25" VerticalAlignment="Center" HorizontalAlignment="Center"
                    BorderBrush="#252535" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.5" Direction="270" ShadowDepth="10"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Background="Transparent" BorderThickness="0" HorizontalAlignment="Right" VerticalAlignment="Top" 
                            Command="{Binding CloseDetailCommand}" Foreground="#A0A0B0" Margin="0,-10,-10,0" ToolTip="Cerrar" Cursor="Hand">
                        <fa:ImageAwesome Icon="Times" Height="16" Foreground="#A0A0B0" Margin="5"/>
                    </Button>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,10,0,15">
                        <StackPanel DataContext="{Binding JuegoDetalle}" Margin="0,0,10,0">
                            
                            <!-- Imagen y Selector -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                                <Border CornerRadius="10" ClipToBounds="True" Width="120" Height="160" BorderBrush="#252535" BorderThickness="1">
                                    <Image Source="{Binding portada_url, Converter={StaticResource Base64ImageConverter}}" Stretch="UniformToFill"/>
                                </Border>
                            </StackPanel>

                            <!-- Campos de Texto con Estilo -->
                            <TextBlock Text="Título del Juego" Foreground="#A0A0B0" FontSize="11" Margin="0,0,0,5" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding titulo}" IsReadOnly="True" Margin="0,0,0,15" Background="#2C2C3E" Foreground="White" Padding="8" BorderThickness="0"
                                     ToolTip="El título no se puede editar."/>

                            <TextBlock Text="Fecha Lanzamiento (YYYY-MM-DD)" Foreground="#A0A0B0" FontSize="11" Margin="0,0,0,5" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding fecha_lanzamiento}" IsReadOnly="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=Border}}" Margin="0,0,0,15" Background="#2C2C3E" Foreground="White" Padding="8" BorderThickness="0"/>

                            <TextBlock Text="Géneros (separados por coma)" Foreground="#A0A0B0" FontSize="11" Margin="0,0,0,5" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding generos_string}" TextWrapping="Wrap" IsReadOnly="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=Border}}" Margin="0,0,0,15" Background="#2C2C3E" Foreground="White" Padding="8" BorderThickness="0"/>

                            <TextBlock Text="Descripción" Foreground="#A0A0B0" FontSize="11" Margin="0,0,0,5" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding descripcion}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="80" IsReadOnly="{Binding DataContext.IsReadOnly, RelativeSource={RelativeSource AncestorType=Border}}" Margin="0,0,0,15" Background="#2C2C3E" Foreground="White" Padding="8" BorderThickness="0"/>

                            <!-- Reseñas del Juego -->
                            <TextBlock Text="Reseñas de Usuarios" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,10,0,10">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Items.Count, ElementName=ResennasLista}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            
                            <ListBox x:Name="ResennasLista" ItemsSource="{Binding DataContext.ResennasJuego, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                     Background="Transparent" BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#202030" CornerRadius="8" Padding="12" Margin="0,0,0,10" BorderBrush="#353545" BorderThickness="1">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="{Binding username}" Foreground="{StaticResource color3}" FontWeight="Bold" Margin="0,0,10,0"/>
                                                    <fa:ImageAwesome Icon="Star" Height="10" Foreground="Yellow" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding puntuacion, StringFormat='{}{0}/5'}" Foreground="LightGray" FontSize="12" VerticalAlignment="Center"/>
                                                    <Border Background="{StaticResource color1}" CornerRadius="3" Padding="4,1" Margin="10,0,0,0" Visibility="{Binding recomendado, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <TextBlock Text="Recomendado" FontSize="10" Foreground="White"/>
                                                    </Border>
                                                    <Border Background="#E53935" CornerRadius="3" Padding="4,1" Margin="10,0,0,0" Visibility="{Binding recomendado, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                        <TextBlock Text="No Recomendado" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding titulo}" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,3"/>
                                                <TextBlock Text="{Binding comentario}" Foreground="Gray" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Botones de Accion -->
                    <StackPanel Grid.Row="2" Orientation="Vertical">
                        <Button Command="{Binding AddGameCommand}"
                                Background="#43A047" Foreground="White" Padding="15,10" Margin="0,0,0,10" Cursor="Hand" BorderThickness="0"
                                Visibility="{Binding IsAddingNew, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <fa:ImageAwesome Icon="Database" Height="14" Foreground="White" Margin="0,0,8,0"/>
                                <TextBlock Text="Añadir a Base de Datos" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding UpdateGameCommand}"
                                Background="{StaticResource color2}" Foreground="White" Padding="15,10" Margin="0,0,0,10" Cursor="Hand" BorderThickness="0"
                                Visibility="{Binding CanEdit, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <fa:ImageAwesome Icon="Save" Height="14" Foreground="White" Margin="0,0,8,0"/>
                                <TextBlock Text="Guardar Modificaciones" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                                
                        <Button Command="{Binding ToggleGameStatusCommand}" Foreground="White" Padding="15,10" Margin="0,0,0,0" Cursor="Hand" BorderThickness="0"
                                Visibility="{Binding CanEdit, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#E53935"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <fa:ImageAwesome Icon="Ban" Height="14" Foreground="White" Margin="0,0,8,0"/>
                                                <TextBlock Text="Desactivar Juego" FontWeight="Bold"/>
                                            </StackPanel>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding JuegoDetalle.activo}" Value="False">
                                            <Setter Property="Background" Value="#43A047"/>
                                            <Setter Property="Content">
                                                <Setter.Value>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <fa:ImageAwesome Icon="Check" Height="14" Foreground="White" Margin="0,0,8,0"/>
                                                        <TextBlock Text="Activar Juego" FontWeight="Bold"/>
                                                    </StackPanel>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
