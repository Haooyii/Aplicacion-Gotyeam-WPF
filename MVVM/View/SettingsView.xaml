<UserControl x:Class="Gotyeam.MVVM.View.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Ajustes de la Aplicación" Foreground="White" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="Configura las preferencias generales de tamaño de ventana y música" Foreground="LightGray" FontSize="14" Margin="0,5,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="#1A1A2A" CornerRadius="10" Padding="30" HorizontalAlignment="Left" Width="500" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="Tamaño de Ventana" Foreground="LightGray" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <ComboBox ItemsSource="{Binding WindowSizes}" SelectedItem="{Binding SelectedWindowSize}" 
                          Background="#2C2C3E" Foreground="Black" Padding="8" FontSize="14" Margin="0,0,0,25" />

                <TextBlock Text="Música de Fondo" Foreground="LightGray" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <CheckBox Content="Activar Música" IsChecked="{Binding IsMusicEnabled}" Foreground="White" FontSize="14" Margin="0,0,0,15"/>
                
                <TextBlock Text="Volumen:" Foreground="LightGray" FontSize="14" Margin="0,0,0,5"/>
                <Slider Minimum="0" Maximum="100" Value="{Binding MusicVolume}" IsEnabled="{Binding IsMusicEnabled}" Margin="0,0,0,20"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
